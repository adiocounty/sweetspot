[
  {
    "name": "Branding and Colors",
    "settings": [
      {
        "type": "select",
        "id": "color_scheme",
        "label": "Color scheme preset",
        "default": "custom",
        "options": [
          {
            "value": "custom",
            "label": "Custom"
          },
          {
            "value": "midnight",
            "label": "Midnight"
          },
          {
            "value": "daylight",
            "label": "Daylight"
          },
          {
            "value": "citrus",
            "label": "Citrus"
          }
        ]
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color",
        "default": "#10212B"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface color",
        "default": "#F4F7FA"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#B8C5D0"
      },
      {
        "type": "color",
        "id": "color_link",
        "label": "Link color",
        "default": "#0A5EA8"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button color",
        "default": "#0A5EA8"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_focus",
        "label": "Focus ring color",
        "default": "#0B7FCE"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text color",
        "default": "#5A6B76"
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social sharing image"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "inter_n6"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "label": "Base font size",
        "min": 14,
        "max": 22,
        "step": 1,
        "default": 16
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading scale (%)",
        "min": 90,
        "max": 140,
        "step": 5,
        "default": 115
      },
      {
        "type": "select",
        "id": "body_line_height",
        "label": "Body line height",
        "default": "1.6",
        "options": [
          {
            "value": "1.4",
            "label": "Tight"
          },
          {
            "value": "1.6",
            "label": "Balanced"
          },
          {
            "value": "1.8",
            "label": "Relaxed"
          }
        ]
      }
    ]
  },
  {
    "name": "Layout and Spacing",
    "settings": [
      {
        "type": "range",
        "id": "container_width",
        "label": "Page width",
        "min": 960,
        "max": 1600,
        "step": 20,
        "default": 1200
      },
      {
        "type": "range",
        "id": "content_width",
        "label": "Reading width",
        "min": 540,
        "max": 980,
        "step": 20,
        "default": 760
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Section spacing",
        "min": 24,
        "max": 120,
        "step": 4,
        "default": 56
      },
      {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid spacing",
        "min": 10,
        "max": 40,
        "step": 2,
        "default": 20
      },
      {
        "type": "range",
        "id": "card_radius",
        "label": "Corner radius",
        "min": 0,
        "max": 28,
        "step": 2,
        "default": 10
      },
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable subtle motion",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "Enable sticky header",
        "default": true
      }
    ]
  },
  {
    "name": "SEO and Social",
    "settings": [
      {
        "type": "textarea",
        "id": "meta_description_override",
        "label": "Default meta description",
        "info": "Used when a page does not provide a description."
      },
      {
        "type": "text",
        "id": "twitter_handle",
        "label": "X / Twitter username",
        "info": "Enter without @"
      },
      {
        "type": "select",
        "id": "twitter_card_type",
        "label": "Twitter card type",
        "default": "summary_large_image",
        "options": [
          {
            "value": "summary_large_image",
            "label": "Large image"
          },
          {
            "value": "summary",
            "label": "Summary"
          }
        ]
      }
    ]
  },
  {
    "name": "Accessibility",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_breadcrumbs_default",
        "label": "Show breadcrumbs on page templates",
        "default": true
      }
    ]
  }
]

