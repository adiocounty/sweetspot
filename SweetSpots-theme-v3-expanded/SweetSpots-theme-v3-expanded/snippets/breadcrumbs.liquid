{% unless request.page_type == 'index' %}
  <nav class="breadcrumbs" aria-label="Breadcrumbs">
    <ol class="breadcrumbs__list" role="list">
      <li class="breadcrumbs__item">
        <a href="{{ routes.root_url }}">Home</a>
      </li>

      {% if request.page_type == 'collection' and collection %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">{{ collection.title }}</li>
      {% elsif request.page_type == 'product' and product %}
        {% if collection %}
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li class="breadcrumbs__item"><a href="{{ collection.url }}">{{ collection.title }}</a></li>
        {% endif %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">{{ product.title }}</li>
      {% elsif request.page_type == 'blog' and blog %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">{{ blog.title }}</li>
      {% elsif request.page_type == 'article' and article %}
        {% if blog %}
          <li class="breadcrumbs__separator" aria-hidden="true">/</li>
          <li class="breadcrumbs__item"><a href="{{ blog.url }}">{{ blog.title }}</a></li>
        {% endif %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">{{ article.title }}</li>
      {% elsif request.page_type == 'search' %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">Search</li>
      {% elsif request.page_type == 'cart' %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">Cart</li>
      {% elsif request.page_type == 'page' and page %}
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>
        <li class="breadcrumbs__item" aria-current="page">{{ page.title }}</li>
      {% endif %}
    </ol>
  </nav>

  {% assign breadcrumb_position = 1 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      {% if request.page_type == 'collection' and collection %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": {{ collection.title | json }},
          "item": {{ shop.url | append: collection.url | json }}
        }
      {% elsif request.page_type == 'product' and product %}
        {% if collection %}
          {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
          ,{
            "@type": "ListItem",
            "position": {{ breadcrumb_position }},
            "name": {{ collection.title | json }},
            "item": {{ shop.url | append: collection.url | json }}
          }
        {% endif %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": {{ product.title | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
      {% elsif request.page_type == 'blog' and blog %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": {{ blog.title | json }},
          "item": {{ shop.url | append: blog.url | json }}
        }
      {% elsif request.page_type == 'article' and article %}
        {% if blog %}
          {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
          ,{
            "@type": "ListItem",
            "position": {{ breadcrumb_position }},
            "name": {{ blog.title | json }},
            "item": {{ shop.url | append: blog.url | json }}
          }
        {% endif %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": {{ article.title | json }},
          "item": {{ shop.url | append: article.url | json }}
        }
      {% elsif request.page_type == 'search' %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": "Search",
          "item": {{ canonical_url | json }}
        }
      {% elsif request.page_type == 'cart' %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": "Cart",
          "item": {{ canonical_url | json }}
        }
      {% elsif request.page_type == 'page' and page %}
        {% assign breadcrumb_position = breadcrumb_position | plus: 1 %}
        ,{
          "@type": "ListItem",
          "position": {{ breadcrumb_position }},
          "name": {{ page.title | json }},
          "item": {{ shop.url | append: page.url | json }}
        }
      {% endif %}
    ]
  }
  </script>
{% endunless %}
