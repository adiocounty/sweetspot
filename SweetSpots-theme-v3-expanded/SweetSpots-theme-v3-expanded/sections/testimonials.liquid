<section class="section">
  <div class="page-width stack">
    <h2>{{ section.settings.heading }}</h2>

    <div class="grid" style="grid-template-columns:repeat({{ section.settings.columns }},minmax(0,1fr));">
      {% for block in section.blocks %}
        <figure class="card stack" {{ block.shopify_attributes }}>
          <blockquote>{{ block.settings.quote }}</blockquote>
          <figcaption class="meta">{{ block.settings.author }}</figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What customers are saying"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Great quality and super fast shipping."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Happy customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
