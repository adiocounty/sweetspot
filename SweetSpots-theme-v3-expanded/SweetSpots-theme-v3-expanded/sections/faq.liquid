<section class="section">
  <div class="page-width content-width stack">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.intro != blank %}
      <p>{{ section.settings.intro }}</p>
    {% endif %}

    <div class="stack">
      {% for block in section.blocks %}
        <details class="card" {{ block.shopify_attributes }}>
          <summary><strong>{{ block.settings.question }}</strong></summary>
          <div class="stack" style="padding-top:0.7rem;">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Answer common customer questions to reduce hesitation and support requests."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Most orders arrive within 3-5 business days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
