<section class="section">
  <div class="page-width">
    <div class="card stack" style="padding:{{ section.settings.padding }}px;{% if section.settings.image %}background-image:linear-gradient(rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}),rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }})),url('{{ section.settings.image | image_url: width: 2200 }}');background-size:cover;background-position:center;color:#fff;{% endif %}">
      {% if section.settings.kicker != blank %}
        <p class="meta">{{ section.settings.kicker }}</p>
      {% endif %}
      <h1>{{ section.settings.heading }}</h1>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <p>
          <a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
        </p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "New release"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build your best storefront"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Showcase products with flexible, conversion-ready sections and built-in accessibility."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 25
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Inner padding",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
