<section class="section">
  <div class="page-width stack">
    <h2>{{ section.settings.heading }}</h2>

    {% if recommendations.performed and recommendations.products_count > 0 %}
      <div class="grid" style="grid-template-columns:repeat({{ section.settings.columns }},minmax(0,1fr));">
        {% for product in recommendations.products limit: section.settings.products_to_show %}
          <article class="card product-card stack">
            {% if product.featured_image %}
              <a href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
                {{ product.featured_image | image_url: width: 760 | image_tag: loading: 'lazy', alt: product.title }}
              </a>
            {% endif %}
            <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p>{{ product.price | money }}</p>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <p>Recommendations will appear once enough product behavior data is available.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
