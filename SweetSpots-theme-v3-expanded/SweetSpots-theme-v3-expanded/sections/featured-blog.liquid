{% assign featured_blog = blogs[section.settings.blog] %}

<section class="section">
  <div class="page-width stack">
    <div class="stack">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.description != blank %}
        <p>{{ section.settings.description }}</p>
      {% endif %}
    </div>

    {% if featured_blog and featured_blog.articles_count > 0 %}
      <div class="blog-grid" role="list">
        {% for article in featured_blog.articles limit: section.settings.articles_to_show %}
          <article class="card article-card stack" role="listitem">
            {% if section.settings.show_image and article.image %}
              <a href="{{ article.url }}" aria-label="Read {{ article.title | escape }}">
                {{ article.image | image_url: width: 760 | image_tag: loading: 'lazy', alt: article.title }}
              </a>
            {% endif %}

            <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>

            {% if section.settings.show_date %}
              <p class="meta">{{ article.published_at | date: "%B %d, %Y" }}</p>
            {% endif %}

            {% if section.settings.show_excerpt %}
              <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            {% endif %}
          </article>
        {% endfor %}
      </div>

      {% if section.settings.show_view_all %}
        <p>
          <a class="button button--secondary" href="{{ featured_blog.url }}">Visit blog</a>
        </p>
      {% endif %}
    {% else %}
      <div class="empty-state">
        <p>Select a blog with at least one article.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Blog",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the journal"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Articles to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View all button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Blog"
    }
  ]
}
{% endschema %}
