<section class="section">
  <div class="page-width stack">
    <h2>{{ section.settings.heading }}</h2>

    <div class="grid" style="grid-template-columns:repeat({{ section.settings.columns }},minmax(0,1fr));">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        <article class="card collection-card stack" {{ block.shopify_attributes }}>
          {% if collection and block.settings.show_image and collection.featured_image %}
            <a href="{{ collection.url }}" aria-label="Browse {{ collection.title | escape }}">
              {{ collection.featured_image | image_url: width: 760 | image_tag: loading: 'lazy', alt: collection.title }}
            </a>
          {% endif %}

          {% if collection %}
            <h3><a href="{{ collection.url }}">{{ collection.title }}</a></h3>
            {% if block.settings.show_count %}
              <p class="meta">{{ collection.products_count }} products</p>
            {% endif %}
          {% else %}
            <h3>{{ block.settings.fallback_title }}</h3>
            <p class="meta">Select a collection for this block.</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Fallback title",
          "default": "Collection"
        },
        {
          "type": "checkbox",
          "id": "show_image",
          "label": "Show image",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_count",
          "label": "Show product count",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
