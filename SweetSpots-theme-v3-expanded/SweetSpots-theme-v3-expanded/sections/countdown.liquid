<section class="section">
  <div class="page-width content-width">
    <div class="card stack" style="text-align:center;">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}

      <p id="Countdown-{{ section.id }}" data-countdown data-end="{{ section.settings.end_date }}" aria-live="polite">
        {{ section.settings.fallback_text }}
      </p>

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <p><a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a></p>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function () {
    var timer = document.getElementById('Countdown-{{ section.id }}');

    if (!timer) {
      return;
    }

    var endDate = timer.getAttribute('data-end');
    var target = new Date(endDate).getTime();

    if (!target) {
      return;
    }

    var interval = setInterval(function () {
      var now = Date.now();
      var distance = target - now;

      if (distance <= 0) {
        timer.textContent = '{{ section.settings.expired_text | escape }}';
        clearInterval(interval);
        return;
      }

      var days = Math.floor(distance / (1000 * 60 * 60 * 24));
      var hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
      var minutes = Math.floor((distance / (1000 * 60)) % 60);

      timer.textContent = days + 'd ' + hours + 'h ' + minutes + 'm remaining';
    }, 60000);

    var now = Date.now();
    var distance = target - now;

    if (distance > 0) {
      var days = Math.floor(distance / (1000 * 60 * 60 * 24));
      var hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
      var minutes = Math.floor((distance / (1000 * 60)) % 60);
      timer.textContent = days + 'd ' + hours + 'h ' + minutes + 'm remaining';
    }
  })();
</script>

{% schema %}
{
  "name": "Countdown",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited-time offer"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Create urgency for launches, seasonal promotions, or event signups."
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date (ISO)",
      "default": "2026-12-31T23:59:00"
    },
    {
      "type": "text",
      "id": "fallback_text",
      "label": "Fallback text",
      "default": "Offer ends soon"
    },
    {
      "type": "text",
      "id": "expired_text",
      "label": "Expired text",
      "default": "Offer ended"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Countdown"
    }
  ]
}
{% endschema %}
