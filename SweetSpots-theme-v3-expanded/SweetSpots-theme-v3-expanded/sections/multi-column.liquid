<section class="section">
  <div class="page-width stack">
    <h2>{{ section.settings.heading }}</h2>

    <div class="grid" style="grid-template-columns:repeat({{ section.settings.columns }},minmax(0,1fr));">
      {% for block in section.blocks %}
        <article class="card stack" {{ block.shopify_attributes }}>
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}

          {% if block.settings.link_label != blank and block.settings.link != blank %}
            <p><a href="{{ block.settings.link }}">{{ block.settings.link_label }}</a></p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Multi Column",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why shoppers choose us"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast delivery"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Use this space to communicate key shopping benefits."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi Column",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
