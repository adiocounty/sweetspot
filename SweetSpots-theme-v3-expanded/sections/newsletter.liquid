<section class="section">
  <div class="page-width content-width">
    <div class="card stack" style="text-align:{{ section.settings.text_align }};">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p>{{ section.settings.subtext }}</p>
      {% endif %}

      {% form 'customer', class: 'stack' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div>
          <label for="NewsletterEmail-{{ section.id }}">Email</label>
          <input
            id="NewsletterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            value="{% if customer %}{{ customer.email }}{% endif %}"
            placeholder="{{ section.settings.placeholder }}"
            autocomplete="email"
            required
            aria-required="true"
          >
        </div>

        <button class="button" type="submit">{{ section.settings.button_label }}</button>

        {% if form.posted_successfully? %}
          <p role="status" aria-live="polite">Thanks for subscribing.</p>
        {% endif %}

        {% if form.errors %}
          <p role="alert">{{ form.errors | default_errors }}</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join our newsletter"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Text",
      "default": "Get updates on product launches, promotions, and new arrivals."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "you@example.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
