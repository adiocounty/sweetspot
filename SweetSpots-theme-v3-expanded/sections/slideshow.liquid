<section class="section">
  <div class="page-width stack">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="grid" style="grid-template-columns:repeat({{ section.settings.columns }},minmax(0,1fr));">
      {% for block in section.blocks %}
        <article class="card stack" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.heading | default: section.settings.heading }}
          {% endif %}

          {% if block.settings.heading != blank %}
            <h3>{{ block.settings.heading }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}

          {% if block.settings.link_label != blank and block.settings.link != blank %}
            <p><a class="button button--secondary" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a></p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Highlights"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Slide heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add supporting copy for this slide."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
