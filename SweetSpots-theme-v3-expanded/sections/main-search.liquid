<section class="section">
  <div class="page-width stack">
    {% if section.settings.show_breadcrumbs %}
      {% render 'breadcrumbs' %}
    {% endif %}

    <h1>{{ section.settings.heading }}</h1>

    <form class="search-form" action="{{ routes.search_url }}" method="get" role="search" aria-label="Site search">
      <div>
        <label class="visually-hidden" for="Search-Template-{{ section.id }}">Search term</label>
        <input
          id="Search-Template-{{ section.id }}"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ section.settings.placeholder }}"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        >
      </div>
      <button class="button" type="submit">{{ section.settings.button_label }}</button>
    </form>

    {% paginate search.results by section.settings.results_per_page %}
      {% if search.performed %}
        <p role="status" aria-live="polite">
          {{ search.results_count }} results for "{{ search.terms }}"
        </p>

        {% if search.results_count > 0 %}
          <div class="search-results" role="list">
            {% for item in search.results %}
              <article class="card result-card stack" role="listitem">
                {% if item.object_type == 'product' and item.featured_image %}
                  <a href="{{ item.url }}" aria-label="{{ item.title | escape }}">
                    {{ item.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: item.title }}
                  </a>
                {% elsif item.object_type == 'article' and item.image %}
                  <a href="{{ item.url }}" aria-label="{{ item.title | escape }}">
                    {{ item.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: item.title }}
                  </a>
                {% endif %}

                <p class="meta">{{ item.object_type | capitalize }}</p>
                <h2><a href="{{ item.url }}">{{ item.title }}</a></h2>

                {% if item.object_type == 'product' %}
                  <p>{{ item.price | money }}</p>
                {% else %}
                  <p>{{ item.content | strip_html | truncate: 120 }}</p>
                {% endif %}
              </article>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav aria-label="Search results pages">
              <div class="stack">
                {% if paginate.previous %}
                  <a class="button button--secondary" href="{{ paginate.previous.url }}">Previous</a>
                {% endif %}
                {% if paginate.next %}
                  <a class="button button--secondary" href="{{ paginate.next.url }}">Next</a>
                {% endif %}
              </div>
            </nav>
          {% endif %}
        {% else %}
          <div class="empty-state">
            <p>No results found. Try a different keyword.</p>
          </div>
        {% endif %}
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main Search",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Search input placeholder",
      "default": "Search products, pages, and articles"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Search button label",
      "default": "Search"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 4,
      "max": 36,
      "step": 4,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Search"
    }
  ]
}
{% endschema %}
