<section class="section">
  <div class="page-width content-width stack" aria-live="polite">
    {% if cart.item_count > 0 %}
      <p><strong>Subtotal:</strong> {{ cart.total_price | money }}</p>
      <p class="muted">Taxes and shipping at checkout.</p>
      <div class="stack">
        <button class="button button--secondary" type="submit" name="update">Update cart</button>
        <button class="button" type="submit" name="checkout">Checkout</button>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Footer",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Cart Footer"
    }
  ]
}
{% endschema %}
