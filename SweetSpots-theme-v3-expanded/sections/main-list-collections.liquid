<section class="section">
  <div class="page-width content-width stack">
    <h1>{{ 'general.list_collections' | t: default: 'All collections' }}</h1>
    <div class="grid" style="grid-template-columns:repeat(3,minmax(0,1fr));">
      {% for collection in collections %}
        <article class="card collection-card stack">
          <h2><a href="{{ collection.url }}">{{ collection.title }}</a></h2>
          <p class="meta">{{ collection.products_count }} products</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List Collections",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "List Collections"
    }
  ]
}
{% endschema %}
