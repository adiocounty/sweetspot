<section class="section">
  <div class="page-width content-width stack">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.video_url != blank %}
      <div class="card">
        {{ section.settings.video_url | external_video_url: autoplay: section.settings.autoplay | external_video_tag }}
      </div>
    {% else %}
      <div class="empty-state">
        <p>Add a YouTube or Vimeo URL in the theme editor to display video content.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch and learn"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Video"
    }
  ]
}
{% endschema %}
